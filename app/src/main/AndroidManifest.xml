<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WavesOfFood">
        <activity
            android:name=".ui.restaurant.RestaurantHomeActivity"
            android:exported="false" />
        <activity
            android:name=".ui.user.FoodDetailsActivity"
            android:exported="true"></activity>
        <activity
            android:name=".ui.user.SearchActivity"
            android:exported="false" />
        <activity
            android:name=".ui.common.ForgetPasswordActivity"
            android:exported="false" />
        <activity
            android:name=".ui.user.UserHome"
            android:exported="true"></activity>
        <activity
            android:name=".ui.common.SignupActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.common.OnBoardingActivity"
            android:exported="false" />
        <activity
            android:name=".ui.common.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".SplashActivity"
            android:exported="true"></activity>
    </application>

</manifest>