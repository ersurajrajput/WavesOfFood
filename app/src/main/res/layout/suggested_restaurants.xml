<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:elevation="10dp"
    android:layout_marginBottom="10dp"
    android:padding="10dp"

    android:background="@drawable/suggestedrestaurants_bg">





   <androidx.cardview.widget.CardView
       android:id="@+id/res_img_card"
       android:layout_width="100dp"
       android:layout_height="100dp"
       android:layout_alignParentStart="true"
       app:cardCornerRadius="20dp"
       android:elevation="1dp"
       android:layout_alignParentTop="true">
       <ImageView
           android:id="@+id/resImg"
           android:layout_width="match_parent"
           android:layout_height="match_parent"
           app:srcCompat="@drawable/sample_img"
           android:scaleType="fitXY" />

   </androidx.cardview.widget.CardView>
    <TextView
        android:id="@+id/resName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pansi Restaurant"
        android:layout_toEndOf="@id/res_img_card"
        android:layout_centerVertical="true"
        android:fontFamily="@font/sen_regular"
        android:textSize="15sp"
        android:layout_marginStart="20dp"/>
 <RelativeLayout
     android:layout_width="wrap_content"
     android:layout_height="wrap_content"
     android:layout_below="@id/resName"
     android:layout_toEndOf="@id/res_img_card"
     android:layout_marginTop="45dp"
     android:layout_marginStart="20dp"
     android:orientation="horizontal">

     <ImageView
         android:id="@+id/iv_star"
         android:layout_width="wrap_content"
         android:layout_height="wrap_content"

         android:layout_centerVertical="true"
         android:layout_alignParentStart="true"

         android:src="@drawable/star" />
     <TextView
         android:id="@+id/resRating"
         android:layout_width="wrap_content"
         android:layout_height="wrap_content"
         android:text="4.7"
         android:layout_toEndOf="@id/iv_star"
         android:layout_centerVertical="true"
         android:layout_marginStart="5dp"
         android:textStyle="bold"
         android:fontFamily="@font/sen_bold"/>
 </RelativeLayout>
    </RelativeLayout>

