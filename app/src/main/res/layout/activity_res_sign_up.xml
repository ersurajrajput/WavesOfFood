<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_dark"
    tools:context=".ui.res.ResSignUpActivity">


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="0dp"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="0dp">



        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/el1"
                app:tint="@color/white"
                android:translationX="-150dp"
                android:translationY="-150dp"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"/>
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/img_vector_line_dark"

                app:tint="@color/orange"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"/>

            <TextView
                android:id="@+id/txt_signup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="150dp"
                android:fontFamily="@font/sen_bold"
                android:text="Restaurant Sing Up"
                android:textColor="@color/white"
                android:textSize="32sp" />
            <TextView
                android:id="@+id/txt_signup1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Please sign up to get started"
                android:fontFamily="@font/sen_regular"
                android:textColor="@color/white"
                android:layout_below="@id/txt_signup"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="5dp"/>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_white_bottom_layout"
                android:minHeight="600dp"
                android:layout_marginTop="50dp"
                android:layout_below="@id/txt_signup1">

                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginLeft="32dp"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/sen_regular"
                    android:text="restaurant NAME"
                    android:textAllCaps="true"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/etResName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_below="@id/tv_name"
                    android:layout_alignParentStart="true"
                    android:layout_marginLeft="32dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginRight="32dp"
                    android:background="@drawable/bg_et1"
                    android:drawableStart="@drawable/icon_user"
                    android:drawablePadding="10dp"
                    android:drawableTint="@color/hint"
                    android:hint="Ladli Restaurant "
                    android:inputType="textPersonName"
                    android:paddingStart="10dp"
                    android:paddingEnd="20dp" />
                <TextView
                    android:id="@+id/tv_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMAIL"
                    android:layout_alignParentStart="true"
                    android:textSize="15sp"
                    android:layout_below="@id/etResName"
                    android:layout_marginLeft="32dp"
                    android:fontFamily="@font/sen_regular"
                    android:layout_marginTop="20dp" />

                <EditText
                    android:id="@+id/etResEmail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_below="@id/tv_email"
                    android:layout_alignParentStart="true"
                    android:layout_marginStart="32dp"
                    android:layout_marginLeft="32dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginRight="32dp"
                    android:background="@drawable/bg_et1"
                    android:drawableStart="@drawable/icon_email"
                    android:drawablePadding="10dp"
                    android:drawableTint="@color/hint"
                    android:hint="example@gmail.com"
                    android:inputType="textEmailAddress"
                    android:paddingStart="10dp"
                    android:paddingEnd="20dp" />

                <TextView
                    android:id="@+id/tv_pass"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASSWORD"
                    android:layout_alignParentStart="true"
                    android:textSize="15sp"
                    android:layout_below="@id/etResEmail"
                    android:layout_marginLeft="32dp"
                    android:fontFamily="@font/sen_regular"
                    android:layout_marginTop="20dp"/>
                <EditText
                    android:id="@+id/etResPass"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_below="@id/tv_pass"
                    android:background="@drawable/bg_et1"
                    android:layout_marginLeft="32dp"
                    android:layout_marginRight="32dp"
                    android:layout_marginTop="10dp"
                    android:inputType="textPassword"
                    android:hint="********"
                    android:layout_alignParentStart="true"
                    android:drawableStart="@drawable/icon_lock"
                    android:drawableEnd="@drawable/icon_eye_off"
                    android:drawableTint="@color/hint"
                    android:paddingStart="10dp"
                    android:drawablePadding="10dp"
                    android:paddingEnd="20dp"/>
                <TextView
                    android:id="@+id/tv_cpass"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Re-Type Password"
                    android:textAllCaps="true"
                    android:layout_alignParentStart="true"
                    android:textSize="15sp"
                    android:layout_below="@id/etResPass"
                    android:layout_marginLeft="32dp"
                    android:fontFamily="@font/sen_regular"
                    android:layout_marginTop="20dp" />
                <EditText
                    android:id="@+id/etCResPass"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_below="@id/tv_cpass"
                    android:background="@drawable/bg_et1"
                    android:layout_marginLeft="32dp"
                    android:layout_marginRight="32dp"
                    android:layout_marginTop="10dp"

                    android:inputType="textPassword"
                    android:hint="********"
                    android:layout_alignParentStart="true"
                    android:drawableStart="@drawable/icon_lock"
                    android:drawableEnd="@drawable/icon_eye_off"
                    android:drawableTint="@color/hint"
                    android:paddingStart="10dp"
                    android:drawablePadding="10dp"
                    android:paddingEnd="20dp"/>

                <Button
                    android:id="@+id/btnSignUp"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_below="@id/etCResPass"
                    android:layout_marginLeft="32dp"
                    android:layout_marginRight="32dp"
                    android:layout_marginTop="32dp"
                    android:layout_alignParentStart="true"
                    android:text="Sign Up"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_orange_btn"
                    android:fontFamily="@font/sen_bold"/>
                <RelativeLayout
                    android:id="@+id/rl1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/btnSignUp"
                    android:layout_marginLeft="50dp"
                    android:layout_marginRight="50dp"
                    android:layout_marginTop="50dp"
                    android:layout_alignParentStart="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="already  have an account?"
                        android:fontFamily="@font/sen_regular"
                        android:textSize="16sp"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentTop="true"/>
                    <TextView
                        android:id="@+id/tvLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Login"
                        android:layout_alignParentEnd="true"
                        android:textColor="@color/orange"
                        android:textAllCaps="true"
                        android:layout_marginRight="32dp"
                        android:fontFamily="@font/sen_bold"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
                <TextView
                    android:id="@+id/txt_OR"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OR"
                    android:layout_below="@id/rl1"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="20dp"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txt_OR"

                    android:orientation="horizontal"
                    android:padding="10dp"

                    android:gravity="center"
                    android:layout_centerHorizontal="true">
                    <ImageView
                        android:id="@+id/ivGoogle"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_marginRight="20dp"
                        android:background="@drawable/bg_white_circle"
                        android:backgroundTint="@color/black"
                        android:padding="15dp"
                        android:src="@drawable/icon_google"
                        app:tint="@color/white" />

                    <ImageView
                        android:id="@+id/ivFacebook"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_marginRight="20dp"
                        android:background="@drawable/bg_white_circle"
                        android:backgroundTint="@color/black"
                        android:padding="15dp"
                        android:src="@drawable/icon_facebook"
                        app:tint="@color/white" />

                    <ImageView
                        android:id="@+id/ivTwitter"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_marginRight="20dp"
                        android:background="@drawable/bg_white_circle"
                        android:backgroundTint="@color/black"
                        android:padding="15dp"
                        android:src="@drawable/icon_twitter"
                        app:tint="@color/white" />
                </LinearLayout>



            </RelativeLayout>

        </RelativeLayout>
    </ScrollView>
</RelativeLayout>