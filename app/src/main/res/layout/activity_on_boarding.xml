<?xml version="1.0" encoding="utf-8"?>

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
    android:id="@+id/main"
        android:gravity="center_horizontal"
        android:background="@android:color/white"
        tools:context=".ui.user.OnBoardingActivity">


        <androidx.cardview.widget.CardView

            android:layout_width="220dp"
            android:layout_height="250dp"
            android:layout_marginTop="100dp"
            android:src="@color/light_gray"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:background="#90A4AE"

            android:scaleType="centerCrop"
            android:layout_gravity="center">
            <ImageView
                android:id="@+id/imageView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"

                android:src="@color/light_gray"

                android:background="#90A4AE"
                android:scaleType="centerCrop"
                android:layout_gravity="center" />
        </androidx.cardview.widget.CardView>

        <!-- Title Text -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All your favorites"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:textColor="#212121"
            android:gravity="center" />

        <!-- Subtitle Text -->
        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Get all your loved foods in one once place,\n you just place the orer we do the rest"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:textColor="#757575" />

        <!-- Indicator Dots -->
        <LinearLayout
            android:id="@+id/indicatorLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Replace these ImageViews with dot drawables -->
            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_margin="4dp"
                android:src="@drawable/dot_selected" />

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_margin="4dp"
                android:src="@drawable/dot_unselected" />

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_margin="4dp"
                android:src="@drawable/dot_unselected" />

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_margin="4dp"
                android:src="@drawable/dot_unselected" />
        </LinearLayout>

        <!-- Next Button -->
        <Button
            android:id="@+id/btn_next"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="32dp"
            android:layout_marginLeft="32dp"
            android:layout_marginRight="32dp"
            android:background="@drawable/orange_btn_bg"
            android:text="NEXT"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <!-- Skip Text -->
        <TextView
            android:id="@+id/btn_skip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skip"
            android:textColor="#757575"
            android:textSize="14sp"
            android:layout_marginTop="16dp"
            android:layout_gravity="center" />

    </LinearLayout>

