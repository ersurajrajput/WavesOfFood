<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_white_bottom_layout"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Top section -->
        <RelativeLayout
            android:id="@+id/rl1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp">

            <TextView
                android:id="@+id/tvTotalNoOfRunningOrders"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:fontFamily="@font/sen_bold"
                android:textSize="20sp"
                android:layout_centerVertical="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Running Orders"
                android:layout_marginStart="5dp"
                android:layout_toEndOf="@id/tvTotalNoOfRunningOrders"
                android:fontFamily="@font/sen_bold"
                android:textSize="20sp"
                android:layout_centerVertical="true" />
        </RelativeLayout>

        <!-- Included layouts -->




           <androidx.recyclerview.widget.RecyclerView
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:layout_marginBottom="100dp"
               android:id="@+id/runningOrdersRecyclerView"/>



        <!-- Bottom Button -->


    </LinearLayout>

    <Button
        android:id="@+id/btnDismiss"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:text="Dismiss"
        android:textColor="@color/white"
        android:background="@drawable/bg_orange_btn"
        android:layout_marginTop="32dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="20dp"/>

</RelativeLayout>
