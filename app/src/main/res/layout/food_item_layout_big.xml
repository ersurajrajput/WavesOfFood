<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="20dp"
    android:elevation="1dp"
    android:padding="10dp"
    android:background="@drawable/bg_white_rec">
<RelativeLayout
    android:id="@+id/rl1"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_centerVertical="true">

    <androidx.cardview.widget.CardView
        android:id="@+id/cvFoodImg"
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:cardCornerRadius="20dp"
         >
        <ImageView
            android:id="@+id/ivFoodImgPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/img_sample"
            android:scaleType="fitXY"/>
    </androidx.cardview.widget.CardView>
</RelativeLayout>

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@id/rl1">
 <TextView
     android:id="@+id/tvFoodName"
     android:layout_width="wrap_content"
     android:layout_height="wrap_content"
     android:text="FoodName"
     android:fontFamily="@font/sen_bold"
     android:textSize="20sp"/>
        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/icon_delete"
            android:layout_marginBottom="20dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"/>
        <ImageView
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/icon_edit"
            android:layout_toStartOf="@id/btnDelete"
            android:layout_marginEnd="20dp"/>

        <TextView
            android:id="@+id/tvFoodPrice"
            android:layout_width="wrap_content"

            android:layout_height="wrap_content"
            android:text="price"
            android:fontFamily="@font/sen_bold"
            android:layout_alignParentEnd="true"
            android:textColor="@color/black"
            android:layout_below="@id/btnDelete"/>
        <TextView
            android:id="@+id/txtFoodPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/tvFoodPrice"
            android:fontFamily="@font/sen_bold"
            android:layout_below="@id/btnDelete"
            android:textColor="@color/black"
            android:text="RS."/>
        <TextView
           android:id="@+id/tvFoodLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="food label"
            android:layout_below="@id/tvFoodName"
            android:background="@drawable/bg_white_rec"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:layout_marginTop="5dp"
            android:backgroundTint="@color/light_orange"
            android:textColor="@color/orange"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
          android:layout_below="@id/tvFoodLabel">
            <ImageView
                android:id="@+id/ivStar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/icon_star"
                android:layout_centerVertical="true"
                app:tint="@color/orange"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvFoodRating"
                android:text="0.0"
                android:layout_toEndOf="@id/ivStar"
                android:layout_centerVertical="true"
                android:fontFamily="@font/sen_bold"
                android:textColor="@color/orange"
                android:textStyle="bold"
                android:layout_marginStart="10dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/txtR"
                android:text="("
                android:layout_toEndOf="@id/tvFoodRating"
                android:layout_marginStart="20dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvTotalNoOfReview"
                android:text="0"
                android:layout_marginStart="5dp"
                android:layout_toEndOf="@id/txtR"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/txtL"
                android:layout_marginStart="5dp"
                android:layout_toEndOf="@id/tvTotalNoOfReview"
                android:text="Reviews  )"/>s
        </RelativeLayout>
    </RelativeLayout>

</RelativeLayout>