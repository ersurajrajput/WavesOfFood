<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="10dp"
    android:elevation="10dp"
    android:background="@drawable/rec_bg">
  <androidx.cardview.widget.CardView
      android:id="@+id/cvFoodImg"
      android:layout_width="match_parent"
      android:layout_height="150dp"
      app:cardCornerRadius="20dp">
      <ImageView
          android:id="@+id/ivFoodImg"
          android:layout_width="match_parent"
          android:layout_height="match_parent"

          android:src="@drawable/sample_img"/>
  </androidx.cardview.widget.CardView>
    <TextView
        android:id="@+id/tvFoodName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Burger Ferguson"
        android:layout_below="@id/cvFoodImg"
        android:fontFamily="@font/sen_bold"
        android:textSize="20sp"
        android:layout_marginTop="10dp"
        />
    <TextView
        android:id="@+id/tvResName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Burger Ferguson"
        android:layout_below="@id/tvFoodName"
        android:fontFamily="@font/sen_regular"
        android:textSize="15sp"
        android:layout_alignParentStart="true"
        android:layout_marginTop="10dp"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvResName"
        android:layout_marginTop="20dp">
        <ImageView
            android:id="@+id/ivRsLogo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/rs_logo"

            android:layout_alignParentStart="true"/>
        <TextView
            android:id="@+id/tvFoodPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/ivRsLogo"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="20sp"/>
        <ImageView
            android:id="@+id/ivAddToCart"
            android:layout_width="30dp"
            android:layout_height="30dp"
         android:layout_marginEnd="10dp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/orange_plus_logo"/>
    </RelativeLayout>




</RelativeLayout>