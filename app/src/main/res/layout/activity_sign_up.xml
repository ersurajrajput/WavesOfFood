<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_dark"
    tools:context=".ui.SignUpActivity">
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/el1"
        app:tint="@color/white"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"/>
   <ImageView
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"
       android:src="@drawable/vector142"
       android:layout_alignParentRight="true"/>
    <TextView
        android:id="@+id/tv_singup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="100dp"
        android:text="Sign Up"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:textStyle="bold"/>

    <RelativeLayout
        android:id="@+id/rl1"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/white_login_bg"
        android:layout_below="@id/tv_singup"
        android:layout_marginTop="32dp">

           <TextView
               android:id="@+id/tv_name"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_alignParentTop="true"
               android:layout_alignParentLeft="true"
               android:textColor="@color/text_color"
               android:layout_marginLeft="32dp"
               android:layout_marginTop="20dp"
               android:text="NAME"/>
           <EditText
               android:id="@+id/et_name"
               android:layout_width="match_parent"
               android:layout_height="50dp"
               android:layout_below="@id/tv_name"
               android:background="@drawable/et_bg"
               android:layout_marginLeft="32dp"
               android:layout_marginTop="5dp"
               android:layout_marginRight="32dp"
               android:hint="john doe"
               android:inputType="text"
               android:textColorHint="@color/hint_color"
               android:paddingLeft="20dp"/>
           <TextView
               android:id="@+id/tv_email"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:text="EMAIL"
               android:textColor="@color/text_color"
               android:layout_below="@id/et_name"
               android:layout_marginTop="20dp"
               android:layout_marginLeft="32dp"
               android:layout_alignParentLeft="true"/>
           <EditText
               android:id="@+id/et_email"
               android:layout_width="match_parent"
               android:layout_height="50dp"
               android:layout_below="@id/tv_email"
               android:layout_alignParentLeft="true"
               android:background="@drawable/et_bg"
               android:layout_marginLeft="32dp"
               android:layout_marginRight="32dp"
               android:layout_marginTop="5dp"
               android:hint="example@gmail.com"
               android:paddingLeft="20dp"
               android:textColorHint="@color/hint_color"/>
           <TextView
               android:id="@+id/tv_pass"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:text="PASSWORD"
               android:textColor="@color/text_color"
               android:layout_below="@id/et_email"
               android:layout_alignParentLeft="true"
               android:layout_marginLeft="32dp"
               android:layout_marginTop="20dp"/>
           <EditText
               android:id="@id/et_pass"
               android:layout_width="match_parent"
               android:layout_height="50dp"
               android:layout_below="@id/tv_pass"
               android:layout_alignParentLeft="true"
               android:background="@drawable/et_bg"
               android:layout_marginLeft="32dp"
               android:layout_marginRight="32dp"
               android:hint="*******"
               android:textColorHint="@color/hint_color"
               android:paddingLeft="20dp"
               android:layout_marginTop="5dp"
               android:inputType="textPassword"
               android:drawableEnd="@drawable/eye_off"
               android:paddingRight="20dp"/>
           <TextView
               android:id="@+id/tv_cpass"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:text="Re-Type Password"
               android:layout_below="@id/et_pass"
               android:textColor="@color/text_color"
               android:layout_alignParentLeft="true"
               android:layout_marginLeft="32dp"
               android:layout_marginTop="20dp"/>
           <EditText
               android:id="@+id/et_cpass"
               android:layout_width="match_parent"
               android:layout_height="50dp"
               android:layout_below="@id/tv_cpass"
               android:layout_alignParentLeft="true"
               android:background="@drawable/et_bg"
               android:layout_marginLeft="32dp"
               android:layout_marginRight="32dp"
               android:layout_marginTop="5dp"
               android:hint="*******"
               android:textColorHint="@color/hint_color"
               android:paddingLeft="20dp"
               android:paddingRight="20dp"
               android:drawableEnd="@drawable/eye_off"
               android:inputType="textPassword"/>
           <Button
               android:id="@+id/btn_singup"
               android:layout_width="match_parent"
               android:layout_height="50dp"
               android:layout_below="@id/et_cpass"
               android:background="@drawable/orange_btn_bg"
               android:layout_marginRight="32dp"
               android:layout_marginLeft="32dp"
               android:layout_marginTop="32dp"
               android:text="Sign Up"
               android:textColor="@color/white"/>
        <RelativeLayout
            android:id="@+id/rl_login"
            android:layout_width="200dp"
            android:layout_marginTop="20dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/btn_singup"
            android:layout_centerHorizontal="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:text="Already have an account?"/>

            <TextView
                android:id="@+id/tv_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:text="Login"
                android:textColor="@color/light_orange" />
        </RelativeLayout>
        <TextView
            android:id="@+id/tv_or"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OR"
            android:layout_below="@id/rl_login"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"/>
        <LinearLayout
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_below="@id/tv_or">
            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"

                android:src="@drawable/google_icon"/>

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginLeft="20dp"
                android:src="@drawable/facebook_logo"/>

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginLeft="20dp"
                android:src="@drawable/google_icon"/>

        </LinearLayout>

    </RelativeLayout>



</RelativeLayout>