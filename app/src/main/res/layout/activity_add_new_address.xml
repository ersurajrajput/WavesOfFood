<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.res.AddNewAddressActivity">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:padding="20dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <RelativeLayout
            android:id="@+id/rlUpper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Map Fragment -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                >

            <fragment
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"

                android:name="com.google.android.gms.maps.SupportMapFragment"
                android:id="@+id/mapView"/>
                <ImageButton
                    android:id="@+id/ibBack"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/icon_back"
                    android:background="@drawable/bg_white_circle"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentStart="true"
                    android:layout_marginTop="32dp"
                    android:layout_marginStart="32dp"
                    app:tint="@color/white"
                    android:backgroundTint="@color/black"/>


            </androidx.cardview.widget.CardView>

            <!-- Overlay Button on map -->


        </RelativeLayout>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Address"
                android:textSize="20sp"
                android:fontFamily="@font/sen_regular"
                android:layout_marginTop="32dp"/>
            <ImageButton
                android:id="@+id/btnTarget"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/icon_target"
                android:background="@drawable/bg_white_circle"
                android:backgroundTint="@color/light_gray"
                app:tint="@color/orange"
               android:layout_alignParentEnd="true"
                android:layout_marginTop="10dp"/>
            </RelativeLayout>

            <EditText
                android:id="@+id/etFullAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="3235 Royal Ln. mesa, new jersy 34567"
                android:padding="20dp"
                android:background="@drawable/bg_et1"
                android:layout_marginTop="20dp"
                android:drawableStart="@drawable/icon_location"
                android:drawablePadding="10dp"
                android:textColorHint="@color/hint"
                android:drawableTint="@color/hint"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:id="@+id/txtStreet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Street"
                        android:textSize="20sp"
                        android:fontFamily="@font/sen_regular"/>
                    <EditText
                        android:id="@+id/etStreet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_et1"
                        android:padding="20dp"
                        android:hint="hason nagar"
                        android:textColorHint="@color/hint"
                        android:layout_below="@id/txtStreet"
                        android:layout_marginTop="10dp"/>
                </RelativeLayout>
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:id="@+id/txtPostCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pincode"
                        android:textSize="20sp"
                        android:fontFamily="@font/sen_regular"/>
                    <EditText
                        android:id="@+id/etPin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_et1"
                        android:padding="20dp"
                        android:layout_below="@id/txtPostCode"
                        android:hint="271406"
                        android:textColorHint="@color/hint"
                        android:inputType="number"
                        android:layout_marginTop="10dp"/>
                </RelativeLayout>

            </LinearLayout>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">
                <TextView
                    android:id="@+id/txtAppartment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Appartment"
                    android:fontFamily="@font/sen_regular"
                    android:textSize="20sp"/>
                <EditText
                    android:id="@+id/etApartmentNo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:padding="20dp"
                    android:background="@drawable/bg_et1"
                    android:layout_below="@id/txtAppartment"
                    android:hint="345"
                    android:textColorHint="@color/hint"/>
            </RelativeLayout>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/txtLabelAs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Label as"
                    android:textSize="20sp"
                    android:fontFamily="@font/sen_regular"
                    android:layout_marginTop="20dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_below="@id/txtLabelAs"
                    android:layout_marginBottom="32dp"
                    android:layout_marginTop="10dp">
                    <Button
                        android:id="@+id/btnHome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:layout_weight="1"
                        android:text="Home"
                        android:background="@drawable/bg_white_rec"/>
                    <Button
                        android:id="@+id/btnWork"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:layout_weight="1"
                        android:text="Work"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_white_rec"/>
                    <Button
                        android:id="@+id/btnOther"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:layout_marginBottom="200dp"
                        android:layout_weight="1"
                        android:text="Other"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_white_rec"/>
                </LinearLayout>
            </RelativeLayout>

        </LinearLayout>

    </ScrollView>
    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="10dp"
        android:padding="20dp"
        android:text="Save location"
        android:background="@drawable/bg_orange_btn"
        android:id="@+id/btnSave"
        android:textColor="@color/white"/>

</RelativeLayout>