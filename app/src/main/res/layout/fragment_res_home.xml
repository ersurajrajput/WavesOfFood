<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.res.Fragments.ResHomeFragment">


    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/llMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <!-- TODO: Update blank fragment layout -->
        <RelativeLayout
            android:id="@+id/rl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageButton
                android:id="@+id/ibDrawer"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/icon_d"
                android:background="@drawable/bg_circle"
                android:elevation="1dp"/>
            <RelativeLayout
                android:id="@+id/rl1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/ibDrawer"
                android:layout_marginStart="20dp"
                android:layout_centerVertical="true">
                <TextView
                    android:id="@+id/txtLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location"
                    android:textAllCaps="true"
                    android:textColor="@color/orange"
                    android:fontFamily="@font/sen_bold"/>
                <TextView
                    android:id="@+id/addressName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Suraj Lab Office"
                    android:layout_below="@id/txtLocation"/>
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/icon_down"
                    android:layout_toEndOf="@id/addressName"
                    android:layout_below="@id/txtLocation"
                    android:layout_marginTop="8dp"
                    android:layout_marginLeft="8dp"
                    app:tint="@color/hint"/>

            </RelativeLayout>
            <androidx.cardview.widget.CardView
                android:layout_width="50dp"
                android:layout_height="50dp"
                app:cardCornerRadius="25dp"
                android:layout_alignParentEnd="true">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/img_sample"
                    android:scaleType="fitXY"/>
            </androidx.cardview.widget.CardView>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/rl2"
            android:layout_width="match_parent"
            android:layout_below="@id/rl"
            android:layout_marginTop="32dp"
            android:layout_height="wrap_content">
            <LinearLayout

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RelativeLayout
                    android:id="@+id/rlRunningOrders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_white_rec"
                    android:padding="20dp"
                    android:layout_marginRight="10dp"
                    android:elevation="1dp"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/tvNoOfRunningOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="50sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Running Orders"
                        android:layout_below="@id/tvNoOfRunningOrders"
                        android:layout_marginTop="20dp"/>
                </RelativeLayout>
                <RelativeLayout
                    android:id="@+id/rlReqOrders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_white_rec"
                    android:elevation="1dp"
                    android:padding="20dp"
                    android:layout_marginLeft="10dp"
                    android:layout_weight="1">
                    <TextView
                        android:id="@+id/tvTotalNoOfReqOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="50sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Order Request"
                        android:layout_below="@id/tvTotalNoOfReqOrders"
                        android:layout_marginTop="20dp"/>

                </RelativeLayout>
            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@drawable/icon_revinue"
                android:scaleType="fitXY"/>
        </RelativeLayout>
        <RelativeLayout
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_white_rec"
            android:layout_marginTop="20dp">
            <TextView
                android:id="@+id/txtRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reviews"
                android:fontFamily="@font/sen_regular"
                android:textSize="20sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/SeeAllReviews"
                android:layout_alignParentEnd="true"
                android:textColor="@color/orange"
                android:fontFamily="@font/sen_regular"
                android:textSize="20sp"/>
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/txtRating"
                android:layout_marginTop="32dp">
                <ImageView
                    android:id="@+id/ivStar"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/icon_star"
                    app:tint="@color/orange"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:id="@+id/tvResRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ivStar"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="10dp"
                    android:text="4.9"
                    android:textColor="@color/orange"
                    android:textSize="20sp"
                    android:fontFamily="@font/sen_bold"/>
                <TextView
                    android:id="@+id/txtTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/tvResRating"
                    android:text="Total"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="20dp"/>
                <TextView
                    android:id="@+id/tvTotalResReview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/txtTotal"
                    android:text="20"
                    android:layout_centerVertical="true"

                    android:layout_marginLeft="10dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/tvTotalResReview"
                    android:text="Reviews"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="10dp"/>
            </RelativeLayout>
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_white_rec"
            android:padding="20dp">
            <TextView
                android:id="@+id/txtPopularItems"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Populer Items This Weeks"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/SeeAll"
                android:layout_alignParentEnd="true"
                android:textColor="@color/orange"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/popularItemsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/txtPopularItems"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"/>



        </RelativeLayout>

    </LinearLayout>

</FrameLayout>