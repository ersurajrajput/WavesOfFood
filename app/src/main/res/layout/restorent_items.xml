<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"

  android:layout_width="match_parent"
android:layout_height="wrap_content"
    android:layout_marginBottom="20dp"

    android:padding="10dp"
    android:id="@+id/restorents_rl">

    <androidx.cardview.widget.CardView
        android:id="@+id/card"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:cardCornerRadius="20dp">
        <ImageView
            android:id="@+id/iv_restorentImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentLeft="true"
            android:background="@color/light_gray"/>
    </androidx.cardview.widget.CardView>
    <TextView
        android:id="@+id/tv_restorentName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="rose garden restaurant"
        android:layout_alignParentLeft="true"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        android:layout_below="@id/card"
        android:textSize="20sp"/>
    <TextView
        android:id="@+id/tv_restorentMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_marginTop="2dp"
        android:text="Burger - Chiken - Riche - Wings "
        android:layout_below="@id/tv_restorentName"/>
    <RelativeLayout
        android:id="@+id/lr_restorent_details"
        android:layout_width="match_parent"
android:layout_marginTop="20dp"
        android:layout_below="@id/tv_restorentMenu"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            android:src="@drawable/star"/>

        <TextView
            android:id="@+id/tv_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:layout_marginLeft="5dp"
            android:layout_toEndOf="@+id/iv_rating"
            android:text="4.7"
            android:layout_centerVertical="true"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/iv_delivery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginStart="30dp"
            android:layout_marginTop="4dp"
            android:layout_toEndOf="@+id/tv_rating"
            android:src="@drawable/vector_transport" />

        <TextView
            android:id="@+id/tv_delivery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginStart="2dp"
            android:layout_marginTop="3dp"
            android:layout_toEndOf="@+id/iv_delivery"
            android:textColor="@color/black"
            android:layout_centerVertical="true"
            android:textStyle="bold"
            android:text="Free" />
        <ImageView
            android:id="@+id/iv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/clock"
            android:layout_toEndOf="@+id/tv_delivery"
            android:layout_marginStart="32dp"/>
        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="20 Min"
            android:layout_toEndOf="@id/iv_time"
            android:layout_marginStart="2dp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_centerVertical="true"/>





    </RelativeLayout>




</RelativeLayout>